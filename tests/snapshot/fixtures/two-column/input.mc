<mc>
  <mc-body>
    <mc-section>
      <mc-column width="50%">
        <mc-image src="https://example.com/photo.jpg" alt="Product photo" width="280px" />
        <mc-spacer height="12px" />
        <mc-text font-size="14px" text-align="center">Product showcase</mc-text>
      </mc-column>
      <mc-column width="50%">
        <mc-text font-size="20px" font-weight="bold">Our Latest Product</mc-text>
        <mc-spacer height="8px" />
        <mc-text>Discover the features that make this product special. Built with quality and care.</mc-text>
        <mc-spacer height="16px" />
        <mc-button href="https://example.com/shop">Shop Now</mc-button>
      </mc-column>
    </mc-section>
  </mc-body>
</mc>
