<mc>

  <mc-head>
    <mc-preview>Welcome to our service</mc-preview>
  </mc-head>
  <mc-body>
  <mc-section>
    <mc-column>
      <mc-text font-size="24px" font-weight="bold" text-align="center">Welcome!</mc-text>
      <mc-spacer height="20px" />
      <mc-text>Thank you for signing up. We're glad to have you on board.</mc-text>
      <mc-spacer height="16px" />
      <mc-button href="https://example.com/get-started">Get Started</mc-button>
      <mc-spacer height="16px" />
      <mc-divider />
      <mc-spacer height="16px" />
      <mc-text font-size="12px" color="#999999" text-align="center">You received this email because you signed up at example.com</mc-text>
    </mc-column>
  </mc-section>
  </mc-body>
</mc>
