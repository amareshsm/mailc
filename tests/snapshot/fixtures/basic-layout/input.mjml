<mjml>
  <mj-head>
    <mj-preview>Welcome to our service</mj-preview>
  </mj-head>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text font-size="24px" font-weight="bold" align="center">Welcome!</mj-text>
        <mj-spacer height="20px" />
        <mj-text>Thank you for signing up. We're glad to have you on board.</mj-text>
        <mj-spacer height="16px" />
        <mj-button href="https://example.com/get-started">Get Started</mj-button>
        <mj-spacer height="16px" />
        <mj-divider />
        <mj-spacer height="16px" />
        <mj-text font-size="12px" color="#999999" align="center">You received this email because you signed up at example.com</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
