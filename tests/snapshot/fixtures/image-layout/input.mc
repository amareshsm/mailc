<mc>
  <mc-body>
    <mc-section>
      <mc-column>
        <mc-image src="https://example.com/hero.jpg" alt="Hero banner" width="600px" />
      </mc-column>
    </mc-section>
    <mc-section>
      <mc-column width="33%">
        <mc-image src="https://example.com/feature1.png" alt="Feature one" width="180px" />
        <mc-text font-size="14px" text-align="center">Feature One</mc-text>
      </mc-column>
      <mc-column width="33%">
        <mc-image src="https://example.com/feature2.png" alt="Feature two" width="180px" />
        <mc-text font-size="14px" text-align="center">Feature Two</mc-text>
      </mc-column>
      <mc-column width="33%">
        <mc-image src="https://example.com/feature3.png" alt="Feature three" width="180px" />
        <mc-text font-size="14px" text-align="center">Feature Three</mc-text>
      </mc-column>
    </mc-section>
    <mc-section>
      <mc-column>
        <mc-image src="https://example.com/logo.png" alt="Company logo" width="120px" href="https://example.com" />
      </mc-column>
    </mc-section>
  </mc-body>
</mc>
