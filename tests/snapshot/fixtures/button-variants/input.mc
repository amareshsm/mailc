<mc>
  <mc-body>
    <mc-section>
      <mc-column>
        <mc-text font-size="18px" font-weight="bold" text-align="center">Button Showcase</mc-text>
        <mc-spacer height="20px" />
        <mc-button href="https://example.com/primary">Primary Button</mc-button>
        <mc-spacer height="12px" />
        <mc-button href="https://example.com/custom" background-color="#e74c3c" color="#ffffff" border-radius="8px" font-size="14px">Red Rounded</mc-button>
        <mc-spacer height="12px" />
        <mc-button href="https://example.com/large" background-color="#27ae60" font-size="20px" padding="16px 48px">Large Green</mc-button>
      </mc-column>
    </mc-section>
  </mc-body>
</mc>
