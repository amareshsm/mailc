<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text font-size="16px" font-weight="bold">Left Column</mj-text>
        <mj-text>This is the left side content without explicit width.</mj-text>
      </mj-column>
      <mj-column>
        <mj-text font-size="16px" font-weight="bold">Right Column</mj-text>
        <mj-text>This is the right side content without explicit width.</mj-text>
      </mj-column>
    </mj-section>
    <mj-section>
      <mj-column>
        <mj-text>Column A</mj-text>
      </mj-column>
      <mj-column>
        <mj-text>Column B</mj-text>
      </mj-column>
      <mj-column>
        <mj-text>Column C</mj-text>
      </mj-column>
    </mj-section>
    <mj-section>
      <mj-column>
        <mj-text>Full width single column</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
