<mc>
  <mc-body>
    <mc-section>
      <mc-column>
        <mc-text font-size="16px" font-weight="bold">Left Column</mc-text>
        <mc-text>This is the left side content without explicit width.</mc-text>
      </mc-column>
      <mc-column>
        <mc-text font-size="16px" font-weight="bold">Right Column</mc-text>
        <mc-text>This is the right side content without explicit width.</mc-text>
      </mc-column>
    </mc-section>
    <mc-section>
      <mc-column>
        <mc-text>Column A</mc-text>
      </mc-column>
      <mc-column>
        <mc-text>Column B</mc-text>
      </mc-column>
      <mc-column>
        <mc-text>Column C</mc-text>
      </mc-column>
    </mc-section>
    <mc-section>
      <mc-column>
        <mc-text>Full width single column</mc-text>
      </mc-column>
    </mc-section>
  </mc-body>
</mc>
