    <!-- ═══ FEATURES — 3 COLUMN ═══════════════════════════════════════════════ -->
    <mc-section class="bg-slate-900 px-6 pb-4">
      <mc-column class="w-1/3 px-2 py-6 bg-slate-800">
        <mc-text class="text-2xl mb-3">⚡</mc-text>
        <mc-text class="text-white text-base font-bold">AI Workflows</mc-text>
        <mc-text class="text-slate-400 text-sm mt-2 leading-relaxed">
          Automate repetitive tasks with intelligent workflow suggestions powered by GPT-4.
        </mc-text>
      </mc-column>
      <mc-column class="w-1/3 px-2 py-6 bg-slate-800">
        <mc-text class="text-2xl mb-3">🔄</mc-text>
        <mc-text class="text-white text-base font-bold">Real-time Sync</mc-text>
        <mc-text class="text-slate-400 text-sm mt-2 leading-relaxed">
          See every change as it happens. Conflict-free collaboration across every timezone.
        </mc-text>
      </mc-column>
      <mc-column class="w-1/3 px-2 py-6 bg-slate-800">
        <mc-text class="text-2xl mb-3">🔐</mc-text>
        <mc-text class="text-white text-base font-bold">Enterprise Security</mc-text>
        <mc-text class="text-slate-400 text-sm mt-2 leading-relaxed">
          SOC 2 Type II certified with end-to-end encryption and SSO support.
        </mc-text>
      </mc-column>
    </mc-section>

    <mc-section class="bg-slate-900 px-6 pb-16">
      <mc-column class="w-1/3 px-2 py-6 bg-slate-800">
