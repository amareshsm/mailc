          class="text-violet-400 font-bold text-sm no-underline inline-block"
        >
          Explore analytics →
        </mc-button>
      </mc-column>
    </mc-section>

    <!-- ═══ SECOND SHOWCASE — 2 COLUMN REVERSED ═══════════════════════════════ -->
