<mc>
  <mc-head>
    <mc-title>Introducing Nexus 2.0 — The Future of Team Collaboration</mc-title>
    <mc-preview>Everything your team needs. One platform, zero friction. Try it free for 30 days.</mc-preview>
  </mc-head>

  <mc-body class="bg-slate-900">

    <!-- ═══ HEADER ═══════════════════════════════════════════════════════════ -->
    <mc-section class="bg-slate-950 px-8 py-4">
      <mc-column class="w-1/3">
        <mc-text class="text-violet-400 text-lg font-bold tracking-tight">
          ◆ nexus
        </mc-text>
      </mc-column>
      <mc-column class="w-2/3">
        <mc-text class="text-slate-400 text-sm text-right">
          <a href="#" class="text-slate-400 no-underline mx-2">Product</a>
          <a href="#" class="text-slate-400 no-underline mx-2">Pricing</a>
          <a href="#" class="text-slate-400 no-underline mx-2">Blog</a>
          <a href="#" class="text-violet-400 font-semibold no-underline ml-4">Log in →</a>
        </mc-text>
      </mc-column>
    </mc-section>

    <!-- ═══ HERO ══════════════════════════════════════════════════════════════ -->
    <mc-section class="bg-slate-900 px-8 pt-16 pb-4">
      <mc-column class="w-full">
        <mc-text class="text-violet-400 text-xs font-bold uppercase tracking-widest text-center mb-4">
          New Release — Version 2.0
        </mc-text>
        <mc-text class="text-white text-5xl font-bold text-center leading-tight">
          Build faster.<br/>Ship together.
        </mc-text>
        <mc-text class="text-slate-400 text-lg text-center mt-6 leading-relaxed">
          Nexus 2.0 brings AI-powered workflows, real-time collaboration,
          and deep integrations to transform the way your team works.
        </mc-text>
      </mc-column>
    </mc-section>

    <!-- Hero CTAs -->
    <mc-section class="bg-slate-900 px-8 py-8">
      <mc-column class="w-1/2 pr-2">
        <mc-button
          href="https://nexus.example.com/signup"
          class="bg-violet-600 text-white text-center py-4 px-6 rounded font-bold text-base w-full block"
        >
          Start free trial →
        </mc-button>
      </mc-column>
      <mc-column class="w-1/2 pl-2">
        <mc-button
          href="https://nexus.example.com/demo"
          class="bg-slate-800 text-white text-center py-4 px-6 rounded font-bold text-base w-full block"
        >
          Watch demo
        </mc-button>
      </mc-column>
    </mc-section>

    <!-- Hero image -->
    <mc-section class="bg-slate-900 px-8 pb-16">
      <mc-column class="w-full">
        <mc-image
          src="https://images.unsplash.com/photo-1551434678-e076c223a692?w=1200&h=600&fit=crop"
          alt="Nexus dashboard preview"
          class="w-full rounded"
        />
      </mc-column>
    </mc-section>

    <!-- ═══ SOCIAL PROOF STATS ════════════════════════════════════════════════ -->
    <mc-section class="bg-slate-800 px-8 py-12">
      <mc-column class="w-1/3 px-2">
        <mc-text class="text-violet-400 text-4xl font-bold text-center">40k+</mc-text>
        <mc-text class="text-slate-300 text-sm text-center mt-2 font-medium">Teams worldwide</mc-text>
      </mc-column>
      <mc-column class="w-1/3 px-2">
        <mc-text class="text-violet-400 text-4xl font-bold text-center">99.9%</mc-text>
        <mc-text class="text-slate-300 text-sm text-center mt-2 font-medium">Uptime SLA</mc-text>
      </mc-column>
      <mc-column class="w-1/3 px-2">
        <mc-text class="text-violet-400 text-4xl font-bold text-center">3× faster</mc-text>
        <mc-text class="text-slate-300 text-sm text-center mt-2 font-medium">Average delivery</mc-text>
      </mc-column>
    </mc-section>

    <!-- ═══ FEATURES HEADER ═══════════════════════════════════════════════════ -->
    <mc-section class="bg-slate-900 px-8 pt-16 pb-8">
      <mc-column class="w-full">
        <mc-text class="text-white text-3xl font-bold text-center">Everything you need</mc-text>
        <mc-text class="text-slate-400 text-base text-center mt-3">
          Purpose-built features that scale with your team from 5 to 5,000.
        </mc-text>
      </mc-column>
