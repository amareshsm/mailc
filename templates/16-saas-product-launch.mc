        <mc-text class="text-slate-500 text-xs mb-2"><a href="#" class="text-slate-500 no-underline">About</a></mc-text>
        <mc-text class="text-slate-500 text-xs mb-2"><a href="#" class="text-slate-500 no-underline">Blog</a></mc-text>
        <mc-text class="text-slate-500 text-xs mb-2"><a href="#" class="text-slate-500 no-underline">Careers</a></mc-text>
