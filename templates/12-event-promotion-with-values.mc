<mc>
  <mc-head>
    <mc-title>Future Tech Summit 2026 - May 18, 2026</mc-title>
    <mc-preview>Join 500+ professionals. Get your ticket now — Early bird pricing ends soon.</mc-preview>
  </mc-head>

  <mc-body class="bg-[#ffffff]">
    <!-- Hero Section -->
    <mc-section class="p-0">
      <mc-column>
        <mc-image
          src="https://placehold.co/1200x300/png?text=Future+Tech+Summit+2026+Hero"
          alt="Future Tech Summit 2026"
          width="600"
          height="300"
        />
      </mc-column>
    </mc-section>

    <!-- Event Header -->
    <mc-section class="bg-[#1a1a1a] py-[40px] px-[32px]">
